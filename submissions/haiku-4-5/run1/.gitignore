## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio cache/options
.vs/
.vscode/
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
*.code-workspace

# Build results
bin/
obj/
out/

# NuGet
*.nupkg
*.snupkg
.nuget/
nuget.config

# ReSharper
.idea/
*.DotSettings
*.DotSettings.user

# Test results
TestResults/
*.trx
coverage.xml
*.opencover.xml
*.lcov

# Local environment
.env
.env.local
appsettings.local.json

# IDE
*.swp
*.swo
*~
.DS_Store

# Docker
docker-compose.override.yml

# Package lock files (optional)
packages.lock.json
