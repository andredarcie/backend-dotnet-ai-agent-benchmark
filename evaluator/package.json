{
  "name": "creditcard-benchmark-evaluator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Automated evaluator for the .NET Credit Card API agent benchmark",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
