# Which submission to evaluate (folder under ../../submissions containing a docker-compose.yml).
TARGET=fable-5/run1

# The live system under test, as seen from the tool containers (submissions publish app on host :8080).
BENCH_BASE_URL=http://host.docker.internal:8080

# Optional first-try hint for the served OpenAPI document (Schemathesis). The evaluator AUTO-DISCOVERS it
# anyway — probing /openapi/v1.json (ASP.NET Core native) and /swagger/v1/swagger.json (Swashbuckle) — so
# this only reorders the probe; a wrong/blank value no longer breaks the contract check.
BENCH_OPENAPI_PATH=/openapi/v1.json

COMPOSE_PROJECT_NAME=bench-harness
