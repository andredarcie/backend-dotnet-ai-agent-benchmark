# Which submission to evaluate (folder under ../../submissions containing a docker-compose.yml).
TARGET=opus-4-8/run1

# The live system under test, as seen from the tool containers (submissions publish app on host :8080).
BENCH_BASE_URL=http://host.docker.internal:8080

# Where the app serves its OpenAPI document (used by Schemathesis).
BENCH_OPENAPI_PATH=/swagger/v1/swagger.json

COMPOSE_PROJECT_NAME=bench-harness
