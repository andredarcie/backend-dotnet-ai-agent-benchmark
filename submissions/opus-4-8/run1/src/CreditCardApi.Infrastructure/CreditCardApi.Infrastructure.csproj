<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Infrastructure layer: EF Core (PostgreSQL), Kafka, outbox dispatcher and PAN encryption.
    Implements the abstractions declared in the Application layer.
  -->
  <PropertyGroup>
    <RootNamespace>CreditCardApi.Infrastructure</RootNamespace>
    <AssemblyName>CreditCardApi.Infrastructure</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\CreditCardApi.Application\CreditCardApi.Application.csproj" />
    <ProjectReference Include="..\CreditCardApi.Domain\CreditCardApi.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Confluent.Kafka" />
    <PackageReference Include="Polly.Core" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>

</Project>
